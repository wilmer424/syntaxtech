<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Taller Pro - Catálogo</title>
    <style>
        body { background-color: #121212; color: white; font-family: sans-serif; text-align: center; padding: 20px; }
        
        /* Grid para las tarjetas */
        .container { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); 
            gap: 20px; 
            margin-top: 30px; 
        }
        
        .card { 
            background: #1e1e1e; 
            padding: 20px; 
            border-radius: 10px; 
            border: 1px solid #333;
        }
        
        .card h3 { color: #58a6ff; }
        
        .btn-pedir { 
            display: inline-block; 
            margin-top: 15px; 
            padding: 10px; 
            background: #58a6ff; 
            color: black; 
            text-decoration: none; 
            border-radius: 5px; 
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h1>CATÁLOGO DE SERVICIOS</h1>
    
    <div class="container">
        <div class="card">
            <h3>Cambio de Aceite</h3>
            <p>Aceite sintético de alta calidad.</p>
            <p><strong>$45.000</strong></p>
            <a href="#" class="btn-pedir">Pedir ahora</a>
        </div>
        
        <div class="card">
            <h3>Kit de Arrastre</h3>
            <p>Instalación profesional incluida.</p>
            <p><strong>$120.000</strong></p>
            <a href="#" class="btn-pedir">Pedir ahora</a>
        </div>
        
        <div class="card">
            <h3>Frenos Nuevos</h3>
            <p>Pastillas de cerámica.</p>
            <p><strong>$65.000</strong></p>
            <a href="#" class="btn-pedir">Pedir ahora</a>
        </div>
    </div>

</body>
</html>
